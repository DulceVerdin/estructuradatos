  <property name="styleSheet">
   <string notr="true">/* --- ESTILO GENERAL DE LA INTERFAZ --- */
QWidget {
    background-color: #FAFAFA;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
    color: #333333;
}

/* --- ESTILO DE LOS LABELS (ETIQUETAS) --- */
QLabel {
    font-weight: 600;
    color: #4A4A4A;
    background: transparent;
    padding: 2px;
}

/* --- ESTILO DEL LINE EDIT (CAMPO DE TEXTO) --- */
QLineEdit {
    background-color: #FFFFFF;
    border: 2px solid #E0E0E0;
    border-radius: 6px;
    padding: 8px 12px;
    color: #333333;
    selection-background-color: #FFB6C1;
}

/* Cuando el usuario hace clic para escribir (Focus) */
QLineEdit:focus {
    border: 2px solid #FF8DA1; /* Rosa vibrante pero sofisticado */
    background-color: #FFF5F7; /* Un sutil fondo rosa claro */
}

/* Si el campo está deshabilitado */
QLineEdit:disabled {
    background-color: #F2F2F2;
    color: #A0A0A0;
    border-color: #E0E0E0;
}

/* --- ESTILO DEL PUSH BUTTON (BOTÓN) --- */
QPushButton {
    background-color: #FF8DA1;
    color: #FFFFFF;
    font-weight: bold;
    border: none;
    border-radius: 6px;
    padding: 10px 20px;
    min-width: 80px;
}

/* Cuando el usuario pasa el mouse por encima (Hover) */
QPushButton:hover {
    background-color: #FFA3B5; /* Rosa un poco más claro */
}

/* Cuando el usuario hace clic (Pressed) */
QPushButton:pressed {
    background-color: #E07387; /* Rosa más oscuro para dar efecto de hundido */
    padding-left: 11px; /* Efecto visual de clic */
    padding-top: 11px;
}

/* Si el botón está deshabilitado */
QPushButton:disabled {
    background-color: #E0E0E0;
    color: #A0A0A0;
}</string>
